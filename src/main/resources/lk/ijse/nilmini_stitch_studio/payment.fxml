<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<AnchorPane fx:id="mainContent"
            prefHeight="729.6"
            prefWidth="1270.4"
            style="-fx-background-color:#f3f4f6;"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="lk.ijse.nilmini_stitch_studio.controller.PaymentController">

    <!-- HEADER -->
    <HBox alignment="CENTER_LEFT"
          prefHeight="60"
          style="-fx-background-color:white; -fx-border-color:#e5e7eb; -fx-border-width:0 0 1 0;"
          AnchorPane.leftAnchor="0"
          AnchorPane.rightAnchor="0"
          AnchorPane.topAnchor="0">
        <children>
            <Text style="-fx-font-size:26px; -fx-font-weight:bold;" text="  Payment" />
        </children>
    </HBox>

    <!-- CONTENT -->
    <VBox alignment="CENTER_LEFT"
          spacing="30"
          AnchorPane.leftAnchor="0"
          AnchorPane.rightAnchor="0"
          AnchorPane.topAnchor="100">

        <!-- CUSTOMER PAYMENT CARD -->
        <Button fx:id="btnCustomerPayment"
                onAction="#clickCustomerPayment"
                prefHeight="120"
                prefWidth="1242.0"
                styleClass="side-btn"
                stylesheets="@css/sideNav.css"
                style="-fx-background-color:white;
                       -fx-background-radius:16;
                       -fx-border-radius:16;
                       -fx-border-color:#e5e7eb;
                       -fx-cursor:hand;">

            <graphic>
                <HBox alignment="CENTER_LEFT" spacing="20">
                    <ImageView fitHeight="47.0" fitWidth="106.0" preserveRatio="true">
                        <image>
                            <Image url="@images/ChatGPT%20Image%20Dec%2013,%202025,%2011_53_38%20PM.png"/>
                        </image>
                    </ImageView>
                    <Text style="-fx-font-size:22px; -fx-font-weight:bold;"
                          text=" Customer Payment"/>
                </HBox>
            </graphic>
        </Button>

        <!-- SUPPLIER PAYMENT CARD -->
        <Button fx:id="btnSupplierPayment"
                onAction="#clickSupplierPayment"
                prefHeight="120"
                prefWidth="1239.0"
                styleClass="side-btn"
                style="-fx-background-color:white;
                       -fx-background-radius:16;
                       -fx-border-radius:16;
                       -fx-border-color:#e5e7eb;
                       -fx-cursor:hand;">

            <graphic>
                <HBox alignment="CENTER_LEFT" spacing="20">
                    <ImageView fitHeight="50.0" fitWidth="79.0" preserveRatio="true">
                        <image>
                            <Image url="@images/ChatGPT%20Image%20Dec%2013,%202025,%2011_48_40%20PM.png"/>
                        </image>
                    </ImageView>
                    <Text style="-fx-font-size:22px; -fx-font-weight:bold;"
                          text="Supplier Payment"/>
                </HBox>
            </graphic>
        </Button>

    </VBox>
</AnchorPane>
