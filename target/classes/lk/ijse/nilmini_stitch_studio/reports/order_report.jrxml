	<parameter name="item Name" class="java.lang.String"/>
	<parameter name="ORDER_ID" class="java.lang.Integer"/>
	<query language="SQL"><![CDATA[SELECT 
    oi.id,
    oi.o_id,
    oi.i_id,
    oi.qty,
    oi.price,
    i.fabric
FROM order_item oi
JOIN item i 
ON oi.i_id = i.i_id
WHERE oi.o_id =$P{ORDER_ID}
]]></query>
